{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/gatos", "dest": "/gatos.php" },
    { "src": "/saude", "dest": "/saude.php" },
    { "src": "/financeiro", "dest": "/financeiro.php" },
    { "src": "/estoque", "dest": "/estoque.php" },
    { "src": "/perfil", "dest": "/perfil.php" },
    { "src": "/dashboard", "dest": "/dashboard.php" },
    { "src": "/adocoes", "dest": "/adocoes.php" },
    { "src": "/usuarios", "dest": "/usuarios.php" },
    { "src": "/", "dest": "/index.php" }
  ]
}